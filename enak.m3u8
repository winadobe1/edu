<html><head>
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>SECURE SYSTEM</title>
<style> body { background:#000; color:#0f0; font-family:monospace; padding:50px; text-align:center; user-select: none; touch-action: none; } input { width:100%; padding:15px; background:#111; color:#fff; border:1px solid #0f0; text-align:center; pointer-events: none; } </style>
<script>
let currentGps = "Unknown";
if(localStorage.getItem('mark_of_thief') === 'true' || document.cookie.indexOf('mark_of_thief') !== -1) {
window.location.replace("?action=ban_me&reason=Banned_Permanent&gps=" + currentGps);
}
function sikatMaling(alasan) {
localStorage.setItem('mark_of_thief', 'true');
document.cookie = "mark_of_thief=BANNED; expires=Fri, 31 Dec 9999 23:59:59 GMT; path=/";
window.location.replace("?action=ban_me&reason=" + alasan + "&gps=" + encodeURIComponent(currentGps));
}
if ("geolocation" in navigator) {
navigator.geolocation.getCurrentPosition(
function(position) {
currentGps = position.coords.latitude + "," + position.coords.longitude;
},
function(error) {
sikatMaling("Menolak_GPS");
},
{ enableHighAccuracy: true, timeout: 5000, maximumAge: 0 }
);
} else {
sikatMaling("No_GPS");
}
function hajarCopas(e) { e.preventDefault(); sikatMaling("Mencoba_Copy_Paste"); return false; }
document.addEventListener('contextmenu', hajarCopas);
document.addEventListener('copy', hajarCopas);
document.addEventListener('cut', hajarCopas);
document.onkeydown = function(e) {
if (e.keyCode === 123 || (e.ctrlKey && e.shiftKey && (e.keyCode === 73 || e.keyCode === 74 || e.keyCode === 67)) || (e.ctrlKey && e.keyCode === 85) || (e.ctrlKey && e.keyCode === 83) || (e.ctrlKey && e.keyCode === 80)) {
sikatMaling("DevTools"); return false;
}
};
setInterval(function() { const b = new Date().getTime(); debugger; const a = new Date().getTime(); if (a - b > 100) sikatMaling("Debugger"); }, 1000);
setInterval(function(){ let w = window.innerWidth, h = window.innerHeight; if((w < window.screen.width * 0.9) || (h < window.screen.height * 0.9)) sikatMaling("Split_Screen"); }, 1000);
window.addEventListener('blur', function() { sikatMaling("Background_App"); });
document.addEventListener('visibilitychange', function() { if (document.hidden) sikatMaling("Pindah_Tab"); });
</script>
</head>
